# Increment the version when modify script
VERSION="1.0.42"

# ============================================================================
# WORKTREE STATE MANAGEMENT
# ============================================================================
# State file (.worktrees.json) lives in the primary repo root and is gitignored.
OPENEMR_ROOT="${OPENEMR_ROOT:-$(
    _root=$(git rev-parse --show-toplevel 2>/dev/null) || { echo "${HOME}/dev/openemr"; exit 0; }
    # --git-common-dir resolves to the shared .git directory.
    # In the primary repo it returns a relative path (.git); in a linked
    # worktree it returns an absolute path inside the primary repo's .git.
    # Using realpath on both lets us compare them reliably.
    _common=$(git rev-parse --git-common-dir 2>/dev/null)
    _common_real=$(realpath "${_common}")
    _primary=$(dirname "${_common_real}")
    if [[ "${_primary}" != "${_root}" ]] && [[ -d "${_primary}" ]]; then
        # We are in a linked worktree — always use the primary repo root
        # so the state file is shared, even on first run before it exists.
        echo "${_primary}"
    else
        # We are in the primary repo
        echo "${_root}"
    fi
)}"
WORKTREE_PARENT="${WORKTREE_PARENT:-$(dirname "${OPENEMR_ROOT}")}"
WT_STATE_FILE="${OPENEMR_ROOT}/.worktrees.json"

# Valid environments (maps to docker/development-<env>/)
VALID_ENVS=("easy" "easy-light" "easy-redis")
DEFAULT_ENV="easy"

wt_die()  { echo "error: $*" >&2; exit 1; }
wt_info() { echo "  --> $*"; }

wt_require_cmd() {
    for cmd in "$@"; do
        if ! command -v "${cmd}" &>/dev/null; then wt_die "'${cmd}' is required but not found"; fi
    done
}

# realpath flag support differs by platform: GNU coreutils has -e/-m; the
# BSD realpath on macOS has neither. BSD's bare realpath already resolves
# symlinks and errors on a missing path (== GNU -e), and every -m call site
# here resolves a path that already exists, so bare realpath is equivalent.
# These are command arrays (not a wrapper function) so realpath stays an
# external command — a function in an || condition trips shellcheck SC2310.
if realpath --version >/dev/null 2>&1; then
    OE_REALPATH_E=(realpath -e)
    OE_REALPATH_M=(realpath -m)
else
    OE_REALPATH_E=(realpath)
    OE_REALPATH_M=(realpath)
fi

wt_init_state() {
    [[ -f "${WT_STATE_FILE}" ]] || echo '{}' > "${WT_STATE_FILE}"
}

wt_state_get() {
    local branch=$1 field=$2
    jq -r --arg b "${branch}" --arg f "${field}" '.[$b][$f] // empty' "${WT_STATE_FILE}"
}

wt_state_set() {
    local branch=$1 offset=$2 dir=$3 env=$4
    local tmp
    tmp=$(mktemp)
    jq --arg b "${branch}" --arg o "${offset}" --arg d "${dir}" --arg e "${env}" \
        '.[$b] = {"offset": ($o|tonumber), "dir": $d, "env": $e}' \
        "${WT_STATE_FILE}" > "${tmp}"
    mv "${tmp}" "${WT_STATE_FILE}"
}

wt_state_remove() {
    local branch=$1
    local tmp
    tmp=$(mktemp)
    jq --arg b "${branch}" 'del(.[$b])' "${WT_STATE_FILE}" > "${tmp}"
    mv "${tmp}" "${WT_STATE_FILE}"
}

wt_next_offset() {
    local used
    used=$(jq '[.[].offset] | sort | .[]' "${WT_STATE_FILE}" 2>/dev/null || true)
    local i=1
    while echo "${used}" | grep -qx "${i}" 2>/dev/null; do
        ((i++))
    done
    echo "${i}"
}

wt_compose_subdir() {
    local env=$1
    echo "docker/development-${env}"
}

wt_validate_env() {
    local env=$1
    for valid in "${VALID_ENVS[@]}"; do
        [[ "${env}" == "${valid}" ]] && return 0
    done
    wt_die "Invalid env '${env}'. Valid options: ${VALID_ENVS[*]}"
}

# Converts a branch name to a Docker-safe slug.
# Docker resource names (volumes, container names, project names) cannot contain
# slashes or other special characters that are valid in git branch names.
# e.g. "feature/my-thing" -> "feature-my-thing"
wt_slug() {
    echo "$1" | tr '/' '-' | tr -cd 'a-zA-Z0-9_-' | tr '[:upper:]' '[:lower:]'
}

# Validates that a worktree dir from state is safe to use for compose operations.
# Guards against corrupted/tampered state by checking:
#   1. dir resolves to a real path (realpath -e)
#   2. it is within WORKTREE_PARENT
#   3. it is a known git worktree of OPENEMR_ROOT
wt_validate_dir() {
    local dir=$1
    local dir_real worktree_parent_real

    # 1. Resolve to real path — fails if path does not exist
    dir_real=$("${OE_REALPATH_E[@]}" "${dir}" 2>/dev/null) \
        || wt_die "Worktree path does not exist or cannot be resolved: '${dir}'"

    # 2. Ensure it is within WORKTREE_PARENT
    worktree_parent_real=$("${OE_REALPATH_E[@]}" "${WORKTREE_PARENT}" 2>/dev/null) \
        || wt_die "Cannot resolve WORKTREE_PARENT: '${WORKTREE_PARENT}'"
    if [[ "${dir_real}" != "${worktree_parent_real}/"* ]]; then
        wt_die "Worktree path '${dir_real}' is not within expected parent '${worktree_parent_real}'"
    fi

    # 3. Ensure it is a registered git worktree of OPENEMR_ROOT.
    # Capture the listing first rather than piping into grep: under pipefail,
    # 'grep -q' exits on first match and SIGPIPEs git mid-write, which git
    # reports as failure (141) once its output exceeds the pipe buffer (many
    # worktrees). A herestring avoids the pipe entirely.
    local worktrees
    worktrees=$(git -C "${OPENEMR_ROOT}" worktree list --porcelain 2>/dev/null) \
        || wt_die "Cannot list git worktrees of '${OPENEMR_ROOT}'"
    if ! grep -Fqx "worktree ${dir_real}" <<< "${worktrees}"; then
        wt_die "Path '${dir_real}' is not a registered git worktree of '${OPENEMR_ROOT}'"
    fi
}

# Non-fatal version of wt_validate_dir for use in listing context.
# Returns 1 on failure instead of calling wt_die (which exits the script),
# so a single bad state entry does not abort the entire list command.
wt_validate_dir_safe() {
    local dir=$1
    local dir_real worktree_parent_real

    dir_real=$("${OE_REALPATH_E[@]}" "${dir}" 2>/dev/null) || return 1

    worktree_parent_real=$("${OE_REALPATH_E[@]}" "${WORKTREE_PARENT}" 2>/dev/null) || return 1
    if [[ "${dir_real}" != "${worktree_parent_real}/"* ]]; then
        return 1
    fi

    local worktrees
    worktrees=$(git -C "${OPENEMR_ROOT}" worktree list --porcelain 2>/dev/null) || return 1
    if ! grep -Fqx "worktree ${dir_real}" <<< "${worktrees}"; then
        return 1
    fi
}

# Resolve the openemr container ID for the managed worktree containing the
# current working directory, or empty if cwd is not in a managed worktree.
# Lets commands invoked from inside a worktree (e.g. a git hook firing
# 'openemr-cmd prek run') dispatch to *that* worktree's container instead
# of falling through to the script's default detection, which can pick the
# wrong container when multiple worktree stacks are running concurrently.
wt_resolve_container_from_cwd() {
    local toplevel toplevel_real branch slug d_real
    toplevel=$(git rev-parse --show-toplevel 2>/dev/null) || return 0
    toplevel_real=$("${OE_REALPATH_M[@]}" "${toplevel}" 2>/dev/null) || return 0
    [[ -f "${WT_STATE_FILE}" ]] || return 0

    while IFS=$'\t' read -r b d; do
        [[ -z "${b}" ]] && continue
        d_real=$("${OE_REALPATH_M[@]}" "${d}" 2>/dev/null) || continue
        if [[ "${d_real}" = "${toplevel_real}" ]]; then
            branch="${b}"
            break
        fi
    done < <(jq -r 'to_entries[] | [.key, .value.dir] | @tsv' "${WT_STATE_FILE}" 2>/dev/null || true)

    [[ -n "${branch:-}" ]] || return 0
    slug=$(wt_slug "${branch}")
    # 2>/dev/null + '|| true': if the docker daemon is unavailable (laptop
    # asleep, daemon not started) docker ps would error and propagate up
    # through 'set -o pipefail', killing the script before the caller can
    # report a clear "no running openemr container" message. Suppress the
    # failure here so the caller treats an empty result the same as a clean
    # "no container found" and emits its own user-facing error.
    docker ps \
        --filter "label=com.docker.compose.project=openemr-${slug}" \
        --filter "label=com.docker.compose.service=openemr" \
        --format "{{.ID}}" 2>/dev/null | head -n 1 || true
}

# ============================================================================
# COMPOSE FILE GENERATORS
# ============================================================================

# Copy the primary repo's base .env into a worktree if (and only if):
#   - source is a regular file (not a symlink — a symlinked source could
#     point outside the primary, allowing a copy of arbitrary content),
#   - dest does not exist as any kind of entry (regular file OR broken
#     symlink — the broken-symlink case fails -e but cp would follow it
#     and write at the link target, potentially outside the worktree).
# Uses cp -p so a 0600 .env on the primary is not widened to 0644 by
# the umask on the copy.
wt_copy_base_env() {
    local primary_root=$1 dest_dir=$2
    local src="${primary_root}/.env"
    local dst="${dest_dir}/.env"

    [[ -f "${src}" && ! -L "${src}" ]] || return 0
    [[ ! -e "${dst}" && ! -L "${dst}" ]] || return 0

    cp -p "${src}" "${dst}"
    wt_info "Copied base .env from primary repo"
}

# shellcheck disable=SC2004
wt_write_env() {
    local dir=$1 branch=$2 offset=$3 env=$4
    local compose_subdir
    compose_subdir=$(wt_compose_subdir "${env}")

    cat > "${dir}/${compose_subdir}/.env" <<ENVEOF
WT_NAME=${branch}
WT_ENV=${env}
WT_OFFSET=${offset}
OPENEMR_DIR=${dir}
WT_HTTP_PORT=$((8300 + ${offset}))
WT_HTTPS_PORT=$((9300 + ${offset}))
WT_MYSQL_PORT=$((8320 + ${offset}))
WT_PMA_PORT=$((8310 + ${offset}))
ENVEOF

    # Services only in easy and easy-redis (not light)
    if [[ "${env}" != "easy-light" ]]; then
        cat >> "${dir}/${compose_subdir}/.env" <<ENVEOF
WT_SELENIUM_PORT=$((4444 + ${offset}))
WT_VNC_PORT=$((7900 + ${offset}))
WT_COUCHDB_PORT=$((5984 + ${offset}))
WT_COUCHDB_SSL_PORT=$((6984 + ${offset}))
WT_MAILPIT_UI_PORT=$((8025 + ${offset}))
WT_MAILPIT_SMTP_PORT=$((1025 + ${offset}))
ENVEOF
    fi

    # Redis only in easy-redis
    if [[ "${env}" == "easy-redis" ]]; then
        cat >> "${dir}/${compose_subdir}/.env" <<ENVEOF
WT_REDIS_PORT=$((6379 + ${offset}))
ENVEOF
    fi
}

wt_write_override() {
    local dir=$1 branch=$2 offset=$3 env=$4
    local slug
    slug=$(wt_slug "${branch}")
    local compose_subdir
    compose_subdir=$(wt_compose_subdir "${env}")

    local lib_root env_root wt_root_real
    # Resolve the worktree root once for bounds checking below
    wt_root_real=$("${OE_REALPATH_E[@]}" "${dir}")

    # Guard against nested symlinks that could resolve volume mount sources
    # outside the worktree (e.g., docker/library -> /etc).
    [[ -L "${dir}/docker/library" ]] && wt_die "Refusing: '${dir}/docker/library' is a symlink"
    lib_root=$("${OE_REALPATH_E[@]}" "${dir}/docker/library")         || wt_die "Missing directory: '${dir}/docker/library'"
    if [[ "${lib_root}/" != "${wt_root_real}/"* ]]; then
        wt_die "Refusing: docker/library resolves outside worktree: '${lib_root}'"
    fi

    [[ -L "${dir}/${compose_subdir}" ]] && wt_die "Refusing: '${dir}/${compose_subdir}' is a symlink"
    env_root=$("${OE_REALPATH_E[@]}" "${dir}/${compose_subdir}")         || wt_die "Missing directory: '${dir}/${compose_subdir}'"
    if [[ "${env_root}/" != "${wt_root_real}/"* ]]; then
        wt_die "Refusing: compose subdir resolves outside worktree: '${env_root}'"
    fi

    # For easy-redis: also guard php.ini since it is mounted directly into the container
    if [[ "${env}" == "easy-redis" ]]; then
        local php_ini="${dir}/${compose_subdir}/php.ini"
        if [[ -e "${php_ini}" ]]; then
            [[ -L "${php_ini}" ]] && wt_die "Refusing: '${php_ini}' is a symlink"
            local php_ini_real
            php_ini_real=$("${OE_REALPATH_E[@]}" "${php_ini}") \
                || wt_die "Cannot resolve: '${php_ini}'"
            if [[ "${php_ini_real}" != "${wt_root_real}" && "${php_ini_real}/" != "${wt_root_real}/"* ]]; then
                wt_die "Refusing: php.ini resolves outside worktree: '${php_ini_real}'"
            fi
        fi
    fi

    # Resolve the primary repo's .git directory. The worktree's own .git is a
    # text file containing 'gitdir: <primary>/.git/worktrees/<wt-dir-basename>',
    # where <wt-dir-basename> is the basename of the worktree directory (in
    # this script's naming, "openemr-wt-<slug>") -- not the branch slug alone.
    # Without exposing that absolute path inside the container, any tool that
    # shells out to git (npm postinstall hooks like husky, lint-staged, prek,
    # composer scripts that read commit metadata, etc.) sees a broken pointer
    # and fails. We bind-mount the primary's .git at the same absolute host
    # path inside the container so the existing pointer resolves transparently.
    local primary_root_real primary_git_real
    primary_root_real=$("${OE_REALPATH_E[@]}" "${OPENEMR_ROOT}") \
        || wt_die "Cannot resolve OPENEMR_ROOT: '${OPENEMR_ROOT}'"
    [[ -L "${primary_root_real}/.git" ]] && wt_die "Refusing: '${primary_root_real}/.git' is a symlink"
    primary_git_real=$("${OE_REALPATH_E[@]}" "${primary_root_real}/.git") \
        || wt_die "Cannot resolve primary .git: '${primary_root_real}/.git'"
    [[ -d "${primary_git_real}" ]] || wt_die "Primary .git is not a directory: '${primary_git_real}'"

    local override_file="${dir}/${compose_subdir}/docker-compose.override.yml"

    # Header + core volumes (all envs)
    cat > "${override_file}" <<OVEOF
# Auto-generated by openemr-cmd worktree add -- do not edit by hand
# Worktree: ${branch}  Env: ${env}  Offset: ${offset}

volumes:
  databasevolume:
    name: openemr-${slug}_db
  assetvolume:
    name: openemr-${slug}_assets
  themevolume:
    name: openemr-${slug}_themes
  sitesvolume:
    name: openemr-${slug}_sites
  nodemodules:
    name: openemr-${slug}_nodemodules
  vendordir:
    name: openemr-${slug}_vendor
  phpstanvolume:
    name: openemr-${slug}_phpstan
  ccdanodemodules:
    name: openemr-${slug}_ccdanodemodules
  ccdanodemodules2:
    name: openemr-${slug}_ccdanodemodules2
  logvolume:
    name: openemr-${slug}_logs
  couchdbvolume:
    name: openemr-${slug}_couchdb
OVEOF

    # mailpit volume only in non-light envs
    if [[ "${env}" != "easy-light" ]]; then
        cat >> "${override_file}" <<OVEOF
  mailpitvolume:
    name: openemr-${slug}_mailpit
OVEOF
    fi

    # Core services (all envs).
    # Ports are handled via WT_* variables with defaults in the base compose.
    # Override needs:
    #   1. The primary repo's .git directory bind-mounted at the same absolute
    #      host path inside the container, so the worktree's .git pointer file
    #      resolves and host-installed git tooling (husky, lint-staged, prek,
    #      etc.) sees a valid repo. Mounted RW because git writes refs,
    #      indexes, packed objects, and the worktree-specific state in
    #      <primary>/.git/worktrees/<slug>/.
    #   2. Library bind-mount absolute paths (relative paths in the base
    #      compose break when the compose file is loaded from a worktree
    #      checkout that does not match the base compose's own directory).
    cat >> "${override_file}" <<OVEOF

services:
  openemr:
    volumes:
      - "${primary_git_real}:${primary_git_real}:rw"
OVEOF

    # easy-redis: php.ini is mounted directly into the openemr container.
    # Append to the openemr service block emitted just above.
    if [[ "${env}" == "easy-redis" ]]; then
        cat >> "${override_file}" <<OVEOF
      - "${env_root}/php.ini:/usr/local/etc/php/php.ini:ro"
OVEOF
    fi

    cat >> "${override_file}" <<OVEOF

  mysql:
    volumes:
      - "${lib_root}/sql-ssl-certs-keys/easy/ca.pem:/etc/ssl/ca.pem:ro"
      - "${lib_root}/sql-ssl-certs-keys/easy/server-cert.pem:/etc/ssl/server-cert.pem:ro"
      - "${lib_root}/sql-ssl-certs-keys/easy/server-key.pem:/etc/ssl/server-key.pem:ro"
OVEOF

    # couchdb library paths — only in easy and easy-redis
    if [[ "${env}" != "easy-light" ]]; then
        cat >> "${override_file}" <<OVEOF

  couchdb:
    volumes:
      - "${lib_root}/couchdb-config-ssl-cert-keys/local.ini:/opt/couchdb/etc/local.ini:rw"
      - "${lib_root}/couchdb-config-ssl-cert-keys/easy/ca.pem:/etc/ssl/ca.pem:ro"
      - "${lib_root}/couchdb-config-ssl-cert-keys/easy/server-cert.pem:/etc/ssl/server-cert.pem:ro"
      - "${lib_root}/couchdb-config-ssl-cert-keys/easy/server-key.pem:/etc/ssl/server-key.pem:ro"
OVEOF
    fi

    # Redis-specific overrides.
    # The base compose uses hardcoded container_name which bypasses Docker project
    # namespacing — override with branch-scoped names so multiple worktrees coexist.
    if [[ "${env}" == "easy-redis" ]]; then
        cat >> "${override_file}" <<OVEOF

  redis-master:
    container_name: openemr-${slug}-redis-master

  redis-replica-1:
    container_name: openemr-${slug}-redis-replica-1

  redis-replica-2:
    container_name: openemr-${slug}-redis-replica-2

  sentinel-1:
    container_name: openemr-${slug}-sentinel-1

  sentinel-2:
    container_name: openemr-${slug}-sentinel-2
OVEOF
    fi
}

# Runs docker compose against a specific worktree's stack
wt_compose_cmd() {
    local branch=$1
    local dir env compose_subdir
    dir=$(wt_state_get "${branch}" dir)
    env=$(wt_state_get "${branch}" env)
    if [[ -z "${dir}" ]]; then wt_die "No worktree found for branch '${branch}'"; fi
    wt_validate_dir "${dir}"
    compose_subdir=$(wt_compose_subdir "${env}")
    check_docker_compose_install
    local slug
    slug=$(wt_slug "${branch}")
    # Security note: docker-compose.yml is intentionally loaded from the
    # worktree checkout so that compose changes on the branch are testable.
    # This tool is designed for use on branches you own and trust — do not
    # run worktree up/down/list against untrusted branches or PRs, as a
    # malicious compose file could mount host paths or run arbitrary images.
    "${DOCKER_COMPOSE_CMD[@]}" \
        --env-file "${dir}/${compose_subdir}/.env" \
        -p "openemr-${slug}" \
        -f "${dir}/${compose_subdir}/docker-compose.yml" \
        -f "${dir}/${compose_subdir}/docker-compose.override.yml" \
        "${@:2}"
}

# ============================================================================
# WORKTREE SUBCOMMANDS
# ============================================================================

# shellcheck disable=SC2004
cmd_worktree_add() {
    local branch="" env="${DEFAULT_ENV}" start=false new_branch=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            --env)           if [[ -z "${2:-}" ]]; then wt_die "--env requires a value"; fi; env=$2; shift 2 ;;
            --start)         start=true; shift ;;
            -b|--new-branch) new_branch=true; shift ;;
            -*)              wt_die "Unknown option: $1" ;;
            *)               if [[ -z "${branch}" ]]; then branch=$1; else wt_die "Unexpected argument: $1"; fi; shift ;;
        esac
    done
    if [[ -z "${branch}" ]]; then wt_die "Usage: openemr-cmd worktree add <branch> [-b] [--env easy|easy-light|easy-redis] [--start]"; fi

    wt_require_cmd git docker jq realpath
    wt_validate_env "${env}"
    wt_init_state

    local existing
    existing=$(wt_state_get "${branch}" dir)
    existing="${existing:-}"
    if [[ -n "${existing}" ]]; then wt_die "Worktree for '${branch}' already exists at ${existing}"; fi

    local compose_subdir
    compose_subdir=$(wt_compose_subdir "${env}")
    if [[ ! -d "${OPENEMR_ROOT}/${compose_subdir}" ]]; then
        wt_die "Compose directory not found: ${OPENEMR_ROOT}/${compose_subdir}"
    fi

    local offset dir dir_slug
    offset=$(wt_next_offset)
    dir_slug=$(wt_slug "${branch}")
    dir="${WORKTREE_PARENT}/openemr-wt-${dir_slug}"

    wt_info "Creating git worktree for '${branch}' at ${dir}"
    if ${new_branch}; then
        git -C "${OPENEMR_ROOT}" worktree add -b "${branch}" "${dir}"
    else
        git -C "${OPENEMR_ROOT}" worktree add "${dir}" "${branch}"
    fi

    wt_info "Setting up compose files (env=${env}, offset=${offset})"

    # Guard against symlink attacks: a malicious branch could commit
    # docker/ or docker/development-<env>/ as a symlink pointing outside
    # the worktree. Refuse to proceed if either is a symlink.
    if [[ -L "${dir}/docker" ]]; then
        git -C "${OPENEMR_ROOT}" worktree remove --force "${dir}" 2>/dev/null || true
        wt_die "Refusing: '${dir}/docker' is a symlink in the checked-out branch"
    fi
    if [[ -L "${dir}/${compose_subdir}" ]]; then
        git -C "${OPENEMR_ROOT}" worktree remove --force "${dir}" 2>/dev/null || true
        wt_die "Refusing: '${dir}/${compose_subdir}' is a symlink in the checked-out branch"
    fi

    mkdir -p "${dir}/${compose_subdir}"

    # Verify the compose subdir resolved within the worktree root (no traversal)
    local wt_root_real compose_dir_real
    wt_root_real=$("${OE_REALPATH_E[@]}" "${dir}")
    compose_dir_real=$("${OE_REALPATH_M[@]}" "${dir}/${compose_subdir}")
    if [[ "${compose_dir_real}/" != "${wt_root_real}/"* ]]; then
        git -C "${OPENEMR_ROOT}" worktree remove --force "${dir}" 2>/dev/null || true
        wt_die "Refusing: compose directory '${compose_dir_real}' is outside worktree root '${wt_root_real}'"
    fi

    wt_write_env      "${dir}" "${branch}" "${offset}" "${env}"
    wt_write_override "${dir}" "${branch}" "${offset}" "${env}"

    # The base-dir .env (e.g., OPENEMR__ENVIRONMENT=dev) is gitignored, so
    # 'git worktree add' does not bring it across. Copy it from the primary so
    # the new worktree's runtime environment matches.
    wt_copy_base_env "${OPENEMR_ROOT}" "${dir}"

    wt_state_set "${branch}" "${offset}" "${dir}" "${env}"

    echo ""
    echo "Worktree '${branch}' ready  [env: ${env}]"
    echo "  Directory : ${dir}"
    echo "  OpenEMR   : https://localhost:$((9300 + ${offset}))  (http: $((8300 + ${offset})))"
    echo "  phpMyAdmin: http://localhost:$((8310 + ${offset}))"
    if [[ "${env}" != "easy-light" ]]; then
        echo "  Mailpit   : http://localhost:$((8025 + ${offset}))"
        echo "  CouchDB   : http://localhost:$((5984 + ${offset}))"
    fi
    if [[ "${env}" == "easy-redis" ]]; then
        echo "  Redis     : localhost:$((6379 + ${offset}))"
    fi
    echo "  MySQL     : localhost:$((8320 + ${offset}))"
    echo ""

    if ${start}; then
        cmd_worktree_up "${branch}"
    else
        echo "Run 'openemr-cmd worktree up ${branch}' to start."
    fi
}

cmd_worktree_remove() {
    local branch="" purge=true

    while [[ $# -gt 0 ]]; do
        case $1 in
            --keep-volumes) purge=false; shift ;;
            -*)      wt_die "Unknown option: $1" ;;
            *)       if [[ -z "${branch}" ]]; then branch=$1; else wt_die "Unexpected argument: $1"; fi; shift ;;
        esac
    done
    if [[ -z "${branch}" ]]; then wt_die "Usage: openemr-cmd worktree remove <branch> [--keep-volumes]"; fi

    if ! [[ -f "${WT_STATE_FILE}" ]]; then wt_die "No worktrees found (state file missing)"; fi
    local dir
    dir=$(wt_state_get "${branch}" dir)
    if [[ -z "${dir}" ]]; then wt_die "No worktree found for branch '${branch}'"; fi

    # If the dir is already gone (deleted out-of-band), skip the destructive
    # steps and just clean up the state entry. Only the "missing" case is
    # graceful here — for dirs that exist but fail validation (outside parent,
    # not a registered worktree, etc.) keep the existing fatal behavior, since
    # that might be in-progress user work we should not silently abandon.
    if [[ ! -e "${dir}" ]]; then
        local slug
        slug=$(wt_slug "${branch}")
        wt_state_remove "${branch}"
        git -C "${OPENEMR_ROOT}" worktree prune 2>/dev/null || true
        wt_info "Worktree dir was already gone; cleaned up state entry for '${branch}'."
        wt_info "Note: docker resources (containers, volumes) for this stack may still exist."
        wt_info "  Clean them manually: docker compose -p openemr-${slug} down -v"
        return 0
    fi

    echo "This will remove worktree '${branch}' at ${dir}."
    if ! ${purge}; then echo "  --keep-volumes: Docker volumes will be preserved."; fi
    read -rp "Continue? [y/N] " confirm
    [[ "${confirm}" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 0; }

    wt_info "Stopping Docker stack"
    if ${purge}; then
        wt_compose_cmd "${branch}" down --volumes 2>/dev/null
    else
        wt_compose_cmd "${branch}" down 2>/dev/null
    fi

    wt_info "Removing git worktree"

    if ! git -C "${OPENEMR_ROOT}" worktree remove --force "${dir}" 2>/dev/null; then
        # Validate dir before recursive delete — guard against corrupted state file
        if [[ -z "${dir}" ]] || \
           [[ "${dir}" != "${WORKTREE_PARENT}/openemr-wt-"* ]] || \
           [[ "${dir}" == "/" ]]; then
            wt_die "Refusing to delete '${dir}': path does not match expected worktree location"
        fi
        rm -rf "${dir}"
    fi
    git -C "${OPENEMR_ROOT}" worktree prune

    wt_state_remove "${branch}"
    wt_info "Done. Worktree '${branch}' removed."
}

# shellcheck disable=SC2004
